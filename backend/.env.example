# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string — update credentials as needed.
DATABASE_URL=postgres://user:password@localhost:5432/ista_goma?sslmode=disable

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use a strong random string of at least 64 characters in production.
JWT_SECRET=change-this-to-a-strong-random-secret-in-production
JWT_EXPIRY_HOURS=24
REFRESH_EXPIRY_HOURS=168

# ─── Google OAuth (optional) ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Resend (email delivery) ─────────────────────────────────────────────────
# Leave empty to enable dry-run mode (emails are only logged, not sent).
RESEND_API_KEY=
EMAIL_FROM_NAME=ISTA-GOMA
EMAIL_FROM_ADDR=noreply@ista-goma.cd

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5000
